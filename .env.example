# Copy to .env and fill in the keys you have. Everything works offline without
# these; they unlock cloud providers, observability, and RAGAS.

# --- LLM / embedding providers ---
OPENAI_API_KEY=
COHERE_API_KEY=
# OpenRouter is OpenAI-compatible (chat only).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

LANGCHAIN_TRACING_V2=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=raglab
